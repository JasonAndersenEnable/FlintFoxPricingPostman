# ── Postman secrets & local config ──────────────────────────────
# Environment files contain API keys, tokens, base URLs — never commit these
*.postman_environment.json
*environment*.json

# Local backup files Postman generates automatically
*.postman_backup

# Postman app local data (if repo is inside Postman's working directory)
.postman/

# ── Keep these (explicitly) ─────────────────────────────────────
# Your actual collection files SHOULD be committed
# !*.postman_collection.json  ← uncomment if you blanket-ignored *.json above

# ── Node / Newman (if you're running collections via CLI) ────────
node_modules/
npm-debug.log*
yarn-error.log*
package-lock.json       # optional — include if you want reproducible installs
.env
.env.*
!.env.example           # safe to commit a template with no real values

# ── OS noise ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor noise ────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── CI/CD & misc ────────────────────────────────────────────────
.nyc_output/
coverage/
*.log
