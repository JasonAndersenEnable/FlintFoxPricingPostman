  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "requests": {},
        "exec": [
          "const tokenUrl = `https://login.microsoftonline.com/${pm.collectionVariables.get('tenant_id')}/oauth2/v2.0/token`;",
          "const clientId = pm.collectionVariables.get('client_id');",
          "const clientSecret = pm.collectionVariables.get('client_secret');",
          "const scope = `api://${clientId}/.default`;",
          "const tokenExpiry = pm.collectionVariables.get('token_expiry');",
          "const currentTime = Math.floor(Date.now() / 1000);",
          "",
          "if (!pm.collectionVariables.get('access_token') || currentTime >= tokenExpiry) {",
          "  pm.sendRequest({",
          "    url: tokenUrl,",
          "    method: 'POST',",
          "    header: { 'Content-Type': 'application/x-www-form-urlencoded' },",
          "    body: {",
          "      mode: 'urlencoded',",
          "      urlencoded: [",
          "        { key: 'grant_type', value: 'client_credentials' },",
          "        { key: 'client_id', value: clientId },",
          "        { key: 'client_secret', value: clientSecret },",
          "        { key: 'scope', value: scope }",
          "      ]",
          "    }",
          "  }, (err, res) => {",
          "    if (!err) {",
          "      const json = res.json();",
          "      pm.collectionVariables.set('access_token', json.access_token);",
          "      pm.collectionVariables.set('token_expiry', currentTime + json.expires_in - 60);",
          "    }",
          "  });",
          "}"
        ]
      }
    },
